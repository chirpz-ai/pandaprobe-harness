# Python / uv
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
dist/
build/

# Environment files (never commit real secrets)
.env
.env.development
.env.staging
.env.production

# Diagnostic filesystem data (persistent /harness volume mount)
harness-data/

# Benchmark sub-project: raw run outputs and per-run harness workspaces are not
# committed; only the aggregated results/summary/ artifacts are.
benchmarks/results/runs/
benchmarks/results/**/raw/
benchmarks/results/**/harness_root/
benchmarks/.env

# OS / editor cruft
.DS_Store
*.swp
.idea/
.vscode/
