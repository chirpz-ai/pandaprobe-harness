# =============================================================================
# PandaProbe Harness - environment template.
#
# Copy to `.env.development` (git-ignored) and override as needed:
#   cp .env.example .env.development
#
# docker-compose.yml reads these via env-var substitution; migrations/env.py
# assembles the synchronous SQLAlchemy URL from the same POSTGRES_* parts.
# =============================================================================

# -- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=panda_admin
POSTGRES_PASSWORD=panda_secret
POSTGRES_DB=panda_harness
# Inside the Docker network use the service name `db`; from the host use
# `localhost`. The Makefile sets POSTGRES_HOST=localhost for migrations.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# -- Optional: full connection string override -------------------------------
# If set, this takes precedence over the POSTGRES_* parts above (used by
# migrations/env.py). Leave unset to compose the URL from the parts.
# DATABASE_URL=postgresql+psycopg2://panda_admin:panda_secret@localhost:5432/panda_harness
