# =============================================================================
# PandaProbe Harness - environment template.
#
# Copy to `.env` (git-ignored) and fill in your credentials:
#   cp .env.example .env
#
# The harness core shells out to the `pandaprobe` CLI, which consumes the
# PANDAPROBE_* variables for authentication. The HARNESS_* variables are read
# by `HarnessConfig.from_env()`.
# =============================================================================

# -- PandaProbe CLI auth (consumed by the `pandaprobe` binary) ----------------
PANDAPROBE_API_KEY=
PANDAPROBE_PROJECT_NAME=
PANDAPROBE_ENDPOINT=https://api.pandaprobe.com

# -- Harness tuning (all optional; defaults shown) ----------------------------
# Root of the harness workspace (mailbox/, traces/, journal.jsonl, rules.jsonl).
# HARNESS_ROOT=/harness
# Name or path of the pandaprobe CLI binary to invoke.
# HARNESS_CLI_BINARY=pandaprobe
# Absolute breach threshold for the agent_reliability metric.
# HARNESS_RELIABILITY_THRESHOLD=0.5
# Absolute breach threshold for the agent_consistency metric.
# HARNESS_CONSISTENCY_THRESHOLD=0.5
# Evaluate every Nth turn per session (1 = every turn).
# HARNESS_EVAL_SAMPLE_EVERY=1
# Global cap on concurrently-running evaluations across all sessions.
# HARNESS_MAX_CONCURRENT_EVALS=4
# Hard budget of eval launches for this process (0 = unlimited).
# HARNESS_MAX_EVALS_PER_RUN=0
# Shadow mode: evaluate + journal, but never post mailbox notices.
# HARNESS_OBSERVE_ONLY=false
# Escalate to a single needs_human notice after this many notices (0 disables).
# HARNESS_CIRCUIT_BREAKER_MAX_NOTICES=5
# Verify the CLI is present and authenticated before the first eval.
# HARNESS_HEALTH_CHECK=true
# Seed local trend history from the backend once per session.
# HARNESS_HYDRATE_HISTORY_FROM_BACKEND=false

# -- Closed-loop self-heal (v0.6) ----------------------------------------------
# New rules start as candidates and are promoted only on evidence (replay or
# forward trial). false restores the v0.5 add -> active behavior.
# HARNESS_RULE_VALIDATION=true
# Forward trial: distinct live sessions observed before a verdict.
# HARNESS_RULE_TRIAL_MIN_SESSIONS=5
# Minimum improvement of the targeted metric to promote a candidate.
# HARNESS_RULE_PROMOTE_MARGIN=0.05
# Maximum tolerated drop on any other case/metric (validation + regression).
# HARNESS_RULE_REGRESS_MARGIN=0.05
# Hard bound on one developer replay invocation (a hung replay degrades to an
# inconclusive case instead of wedging validation/regression).
# HARNESS_REPLAY_TIMEOUT_S=300
# Capture breaching sessions as replayable eval cases (stores session data).
# HARNESS_CAPTURE_EVAL_CASES=false
# Eval-set corpus cap; oldest failures evict first, wins never.
# HARNESS_EVAL_CASE_MAX=200
# Cases replayed per regression run (0 = all).
# HARNESS_REGRESSION_SAMPLE=0
# Inject only global rules + the top-k relevant rules into the context.
# HARNESS_RULE_RETRIEVAL=true
# How many tagged rules retrieval keeps in the system context.
# HARNESS_RULES_CONTEXT_TOPK=8
