# =============================================================================
# PandaBench — environment template. Copy to `.env` (git-ignored) and fill in.
#   cp .env.example .env
#
# Every model call in the study goes through LiteLLM, so credentials are the
# standard provider env vars LiteLLM reads. The PANDAPROBE_* vars are consumed
# by the `pandaprobe` CLI (which the harness shells out to) and the SDK tracer.
# The HARNESS_* vars are NOT set here — harness_glue sets them programmatically
# per run so each (benchmark x model x arm x seed) gets a fresh workspace.
# =============================================================================

# -- Vertex AI (PRIMARY platform; serves Gemini + Claude partner models) ------
# Auth via Application Default Credentials: `gcloud auth application-default login`
VERTEXAI_PROJECT=
VERTEXAI_LOCATION=us-east5

# -- OpenAI (OpenAI's own API; Vertex does not serve GPT) ---------------------
OPENAI_API_KEY=

# -- Anthropic (the second Claude backend, switchable per run) ----------------
ANTHROPIC_API_KEY=

# Default backend for Claude model keys when neither --backend nor a per-model
# default in models.yaml is given. One of: vertex_ai | anthropic.
CLAUDE_BACKEND=vertex_ai

# -- PandaProbe platform (harness scoring + SDK tracing) ----------------------
# The `pandaprobe` CLI must be on PATH and authenticated. PROJECT_NAME is used
# as-is for BOTH the SDK traces and the harness eval runs — set it to the
# PandaProbe project you want this study's data in (create it in the app first).
# Both paths must agree, so the suite never overrides this value.
PANDAPROBE_API_KEY=
PANDAPROBE_PROJECT_NAME=pandabench
PANDAPROBE_ENDPOINT=https://api.pandaprobe.com

# -- AppWorld isolated env (set by `make setup`; needed for real AppWorld runs) -
# AppWorld runs out-of-process (pydantic v1). `scripts/setup_appworld.sh` prints
# these; pandabench launches the server and drives it over HTTP.
# PANDABENCH_APPWORLD_PYTHON=/Users/you/.pandabench/awenv/bin/python
# APPWORLD_ROOT=/Users/you/.pandabench/appworld
# Or point at an already-running server (skips launch):
# PANDABENCH_APPWORLD_URL=http://127.0.0.1:9000
